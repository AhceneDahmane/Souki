generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("visitor") // visitor, organizer, seller, admin
  phone     String?
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  souks         Souk[]
  vehicles      Vehicle[]
  bids          Bid[]
  registrations SoukRegistration[]
  payments      Payment[]
  favorites     Favorite[]
  notifications Notification[]
}

model Souk {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String
  lat         Float?
  lng         Float?
  date        DateTime
  startTime   String   // HH:mm
  endTime     String?  // HH:mm
  spots       Int      // total spots
  spotPrice   Float    // price per spot
  services    String?  // optional services (JSON string)
  status      String   @default("pending") // pending, active, completed, cancelled
  paid        Boolean  @default(false)
  organizerId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer     User              @relation(fields: [organizerId], references: [id])
  registrations SoukRegistration[]
  vehicles      Vehicle[]
  payments      Payment[]
}

model Vehicle {
  id          String   @id @default(cuid())
  title       String   // e.g. "Renault Clio 4"
  brand       String
  model       String
  year        Int?
  mileage     Int?
  fuelType    String?  // essence, diesel, électrique, hybride
  description String?
  price       Float?   // optional, null = negotiable
  priceType   String   @default("negotiable") // fixed, negotiable
  images      String?  // JSON array of image URLs
  qrCode      String?  // QR code for visitor access
  status      String   @default("pending") // pending, assigned, sold
  soukId      String?
  sellerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  souk        Souk?             @relation(fields: [soukId], references: [id])
  seller      User              @relation(fields: [sellerId], references: [id])
  bids        Bid[]
  accessLogs  VehicleAccess[]
  favorites   Favorite[]
}

model SoukRegistration {
  id          String   @id @default(cuid())
  soukId      String
  sellerId    String
  spotNumber  Int?     // assigned by organizer when scanning QR
  qrCode      String   // QR code for entry
  status      String   @default("pending") // pending, accepted, rejected, present
  paid        Boolean  @default(false)
  createdAt   DateTime @default(now())

  souk   Souk  @relation(fields: [soukId], references: [id])
  seller User  @relation(fields: [sellerId], references: [id])

  @@unique([soukId, sellerId])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  vehicleId String
  visitorId String
  status    String   @default("active") // active, outbid, won, lost
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  visitor User    @relation(fields: [visitorId], references: [id])
}

model VehicleAccess {
  id        String   @id @default(cuid())
  vehicleId String
  visitorId String?
  scannedAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([userId, vehicleId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // bid_outbid, new_bid, registration_accepted, registration_rejected, souk_status, vehicle_sold
  title     String
  message   String
  link      String?  // URL to navigate to
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  type        String   // recharge, souk_creation, registration
  amount      Float    // positive for credits, negative for debits
  description String
  referenceId String?  // soukId or registrationId
  status      String   @default("completed") // pending, completed, failed
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  souk Souk? @relation(fields: [referenceId], references: [id])
}
